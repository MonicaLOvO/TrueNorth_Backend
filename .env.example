# =============================================================================
# TrueNorth Backend – Environment variables
# =============================================================================
# Copy this file to .env and fill in the values. Never commit .env to git.
# On Render, set these in the dashboard under Environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Port the app listens on. Render sets PORT automatically.
PORT=3000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Local dev: use your local Postgres. Render: use the Postgres add-on URL or
# set each variable from the add-on's connection info.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=truenorth

# -----------------------------------------------------------------------------
# Auth (JWT) – required for POST /auth/register, /auth/login, GET /auth/me
# -----------------------------------------------------------------------------
# Generate a long random string (e.g. openssl rand -base64 32). Never commit real secrets.
JWT_SECRET=replace_with_a_long_random_secret
# Optional. Access token lifetime in seconds (default 86400 = 1 day).
# JWT_EXPIRES_IN_SECONDS=86400

# -----------------------------------------------------------------------------
# AI / LLM
# -----------------------------------------------------------------------------
# Optional env fallback key. Main keys can be stored in DB via /ai/connections.
# OPENAI_API_KEY=sk-...
# Set to true to force mock mode (no real API calls).
# AI_USE_MOCK=true
# Required if you want to save AI keys in DB and auto-switch between them.
# AI_CONNECTION_ENCRYPTION_KEY=replace_with_a_long_random_secret
# Optional local fallback settings for Ollama provider.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# Optional. When set, voice transcription uses Deepgram instead of OpenAI Whisper.
# DEEPGRAM_API_KEY=
